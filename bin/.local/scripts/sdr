#!/usr/bin/env bash
# =========================================================
# Tool: sdr - Interactive Search & Replace
# Author: Rob Meijerink (Solvalutions)
# Performance: O(n) file discovery, O(m) replacement
# =========================================================

# Check for dependencies
for tool in gum fd sad rg; do
    if ! command -v "$tool" >/dev/null; then
        echo "Error: $tool is not installed."
        exit 1
    fi
done

gum style --foreground 4 "--- Solvalutions Global Search & Replace ---"

# 1. Inputs with validation
FIND=$(gum input --placeholder "String to find (regex supported)")
[[ -z "$FIND" ]] && exit 0

REPLACE=$(gum input --placeholder "Replace with")
[[ $? -ne 0 ]] && exit 0

WHERE=$(gum input --placeholder "Directory to search (default: .)")
WHERE=${WHERE:-.}

# 2. Execution Logic
# We use ripgrep (rg) to find files containing the pattern first.
# This is significantly faster than piping every file in the system to sad.
echo "Scanning $WHERE for '$FIND'..."

rg --files-with-matches "$FIND" "$WHERE" | sad "$FIND" "$REPLACE"
