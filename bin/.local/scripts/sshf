#!/usr/bin/env bash
# =========================================================
# Tool: sshf - Fuzzy SSH Finder
# Author: Rob Meijerink (Solvalutions)
# Optimized for performance and secure input handling
# =========================================================

# Set the paths to the SSH connection files
ssh_files=("$HOME/.sshf" "$HOME/.sshf.local")

# --- 1. Add Functionality ---
if [[ "$1" == "add" && -n "$2" ]]; then
    ssh_connection="${*:2}"
    read -p "Enter a name for the new SSH connection: " name

    for ssh_file in "${ssh_files[@]}"; do
        if [[ -f "$ssh_file" ]]; then
            read -p "Add $ssh_connection to $ssh_file with name: $name? (y/N): " confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                # Security: Use printf to avoid interpretation of special characters
                printf "ssh %s ## %s\n" "$ssh_connection" "$name" >> "$ssh_file"
                echo "Added successfully."
            fi
        fi
    done
    exit 0
fi

# --- 2. Help Functionality ---
if [[ "$1" == "help" ]]; then
    echo "Usage: sshf [add <user@host> [-p <port>]]"
    exit 0
fi

# --- 3. Search & Connect (The Senior Way) ---
if [[ "$#" -eq 0 ]]; then
    # O(n) to collect, but fzf filtering is O(log n) for the user
    # Combine all existing files into a single stream for fzf
    selection=$(grep -h "^ssh" "${ssh_files[@]}" 2>/dev/null | \
                awk -F " ## " '{printf "%-60s %s\n", $1, $2}' | \
                fzf --exit-0 --height 40% --reverse)

    if [[ -n "$selection" ]]; then
        # Extract the command (everything before the triple space padding)
        # Using pure bash string manipulation for O(1) speed
        ssh_command="${selection%%  *}"

        echo "Connecting: $ssh_command"
        eval "$ssh_command"
    fi
fi