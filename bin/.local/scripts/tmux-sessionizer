#!/usr/bin/env bash

# 1. Select the target directory
if [[ $# -eq 1 ]]; then
    selected="$1"
else
    selected=$({
        printf "%s\n" "$HOME/projects" "$HOME/.dotfiles"
        fd --min-depth 1 --max-depth 1 --type d --hidden . ~/projects ~/.dotfiles 2>/dev/null
    } | fzf)
fi

[[ -z "$selected" ]] && exit 0

selected="${selected%/}"

# 2. Prepare session name (O(1) - No forks)
name="${selected##*/}"
selected_name="${name//[ .:]/_}"

# 3. Execution Logic
if ! tmux has-session -t "=$selected_name" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

# 4. Attachment Logic
if [[ -z "$TMUX" ]]; then
    exec tmux attach-session -t "=$selected_name"
else
    tmux switch-client -t "=$selected_name"
fi