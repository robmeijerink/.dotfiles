#!/usr/bin/env bash
# =========================================================
# Tool: t - Smart Tmux Session Manager
# Inspired by: joshmedeski (https://github.com/joshmedeski)
# Performance: Native Bash string manipulation for O(1) path formatting
# =========================================================

# Helper voor native path replacement (geen sed nodig)
format_path() {
    local p="$1"
    echo "${p/#$HOME/\~}"
}

unformat_path() {
    local p="$1"
    echo "${p/#\~/$HOME}"
}

# --- 1. Header & UI Setup ---
BORDER_LABEL=" t - Session Manager "
HEADER=" ctrl-s: sessions / ctrl-x: zoxide / ctrl-d: directory"

# --- 2. Bindings & Logic ---
# Gebruik native bash voor de zoxide query resultaten
ZOXIDE_BIND="ctrl-x:change-prompt(zoxide> )+reload(zoxide query -l)"

if command -v fd &>/dev/null; then
    DIR_BIND="ctrl-d:change-prompt(directory> )+reload(fd --type d --hidden --max-depth 1 . ~/projects ~/dotfiles)"
else
    DIR_BIND="ctrl-d:change-prompt(directory> )+reload(find ~/projects ~/dotfiles -maxdepth 1 -type d)"
fi

# --- 3. UI Execution ---
# Beslis of we fzf of fzf-tmux (popup) gebruiken
FZF_CMD="fzf"
[[ -n "$TMUX" ]] && FZF_CMD="fzf-tmux -p 60%,50%"

if [[ $# -eq 0 ]]; then
    RESULT=$({
        tmux list-sessions -F '#S' 2>/dev/null
        zoxide query -l
    } | $FZF_CMD \
        --bind "$DIR_BIND" \
        --bind "$ZOXIDE_BIND" \
        --border-label "$BORDER_LABEL" \
        --header "$HEADER" \
        --no-sort)
else
    # Directe jump naar argument
    RESULT=$(zoxide query "$1" || echo "$1")
fi

# --- 4. Finalize & Switch ---
[[ -z "$RESULT" ]] && exit 0

# Verwerk resultaat (basenaam als sessienaam, punten/spaties naar underscores)
RESULT=$(unformat_path "$RESULT")
zoxide add "$RESULT" 2>/dev/null
SESSION_NAME=$(basename "$RESULT" | tr ' .:' '___')

# Switch logic (O(1) tmux lookup)
if ! tmux has-session -t="$SESSION_NAME" 2>/dev/null; then
    tmux new-session -ds "$SESSION_NAME" -c "$RESULT"
fi

if [[ -z "$TMUX" ]]; then
    tmux attach -t "$SESSION_NAME"
else
    tmux switch-client -t "$SESSION_NAME"
fi
