# ====================================================================
# LOCAL OVERRIDES TEMPLATE (Machine-Specific Hardware)
# ====================================================================
# HOW TO USE THIS FILE:
# 1. Do NOT edit this .example file directly for your active setup.
# 2. Copy it: cp ~/.config/sway/conf.d/local.conf.example ~/.config/sway/conf.d/local.conf
# 3. Edit the new 'local.conf' with your specific hardware values.
#
# NOTE: '*.conf' files in this directory are git-ignored to prevent
# leaking hardware setups or secrets to the dotfiles repository.
# ====================================================================

# =========================================================
# Multi-Monitor Configuration
# =========================================================
# Run 'swaymsg -t get_outputs' in your terminal to find your exact
# display identifiers (e.g., DP-1, HDMI-A-1, or eDP-1 for laptops).
# Assign workspaces to specific monitors for predictable workflows.

workspace 1 output DP-1
workspace 2 output DP-1
workspace 3 output DP-1
workspace 4 output DP-1
workspace 5 output DP-1

workspace 6 output HDMI-A-1
workspace 7 output HDMI-A-1
workspace 8 output HDMI-A-1
workspace 9 output HDMI-A-1
